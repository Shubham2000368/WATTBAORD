{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/sprints/layout,_N_T_/sprints/page,_N_T_/sprints"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/sprints/__PAGE__",
    "/sprints",
    "/_index",
    "/_head"
  ]
}